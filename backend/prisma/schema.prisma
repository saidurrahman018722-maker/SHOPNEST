generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  user
  admin
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_AUTH
}

enum OrderStatus {
  pending
  shipped
  delivered
}
model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  verified  Boolean   @default(false)
  role      Role      @default(user)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relations
  sessions  Session[]
  opts      Otp[]
  orders    Order[]   // <-- Added: Links User to their Orders
}

model Otp {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      OtpType  @default(EMAIL_VERIFICATION)
  createdAt DateTime @default(now())
  expiresAt DateTime 

  @@index([userId]) 
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent    String?  // Stores browser/device info
  ipAddress    String?  // Stores client IP address
  createdAt    DateTime @default(now())
  revoked      Boolean  @default(false) 
  expiresAt    DateTime

  @@index([userId])
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float    
  category    String
  stock       Int      
  imageUrl    String
  createdAt   DateTime    @default(now())
  rating      Float       @default(0)
  numReviews  Int         @default(0)
  
  // Relations
  orderItems  OrderItem[] // <-- Added: Links Product to Order Items
}

// ---------------------------------------------------------
// E-COMMERCE (Orders)
// ---------------------------------------------------------

model Order {
  id          String      @id @default(uuid())
  
  // User Relation
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  
  // Order Details
  totalAmount Float
  paymentId   String
  status      OrderStatus @default(pending)

  // Flattened Address Fields
  addressFullName   String
  addressStreet     String
  addressCity       String
  addressPostalCode String
  addressCountry    String

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation for Items
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  
  // Order Relation
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Product Relation
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Item Details
  qty       Int     
  price     Float
}